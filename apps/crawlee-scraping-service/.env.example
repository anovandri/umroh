# ============================================================
# Crawlee Scraping Service — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3100
LOG_LEVEL=info

# Authentication token — must match Spring Boot's outbound token
SERVICE_TOKEN=change-me-in-production

# Set to true to skip auth checks during local development
SKIP_AUTH=true

# ── Spring Boot Integration ──────────────────────────────────
# URL of the Spring Boot backend that receives scraped data
SPRING_BOOT_URL=http://localhost:8080

# Timeout and retry settings for Spring Boot callbacks
CALLBACK_TIMEOUT_MS=10000
CALLBACK_MAX_RETRIES=3

# ── Redis / Bull Queue ───────────────────────────────────────
REDIS_URL=redis://localhost:6379
SCRAPE_QUEUE_NAME=scrape-jobs
QUEUE_CONCURRENCY=3
MAX_JOB_ATTEMPTS=3
JOB_BACKOFF_DELAY_MS=5000
JOB_TTL_MS=86400000

# ── Crawlee Settings ─────────────────────────────────────────
# Directory for Crawlee request queue / storage
CRAWLEE_STORAGE_DIR=./crawlee-storage

# Set to true to start fresh on each run (no resume)
CRAWLEE_PURGE_ON_START=false

# Max requests per crawl job
MAX_REQUESTS_PER_CRAWL=500

# Max parallel browser pages / HTTP requests
MAX_CONCURRENCY=5

# Navigation timeout in seconds (Playwright)
NAVIGATION_TIMEOUT_SECS=60

# Request timeout in seconds
REQUEST_TIMEOUT_SECS=30

# Max retries per individual request
MAX_REQUEST_RETRIES=3

# Delay between requests to the same domain (seconds)
SAME_DOMAIN_DELAY_SECS=1.0

# ── Playwright ───────────────────────────────────────────────
# Run browser in headless mode (false = visible window)
HEADLESS=true

# Ignore SSL errors (useful for dev/staging environments)
IGNORE_SSL_ERRORS=false

# ── Job Processing ───────────────────────────────────────────
# How many packages to batch before sending to Spring Boot
BATCH_SIZE=20

# Max retries for a failed job before marking as FAILED
MAX_JOB_RETRIES=3
