{
  "name": "@umroh/crawlee-scraping-service",
  "version": "1.0.0",
  "description": "Crawlee-based web scraping microservice for Umroh/Hajj travel packages",
  "main": "src/index.ts",
  "scripts": {
    "start": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/index.ts",
    "start:prod": "node ../../dist/apps/crawlee-scraping-service/index.js",
    "build": "tsc -p tsconfig.app.json",
    "test": "jest --config jest.config.ts",
    "lint": "eslint src --ext .ts",
    "playwright:install": "playwright install chromium --with-deps"
  },
  "dependencies": {
    "crawlee": "^3.7.0",
    "playwright": "^1.40.0",
    "express": "^4.18.2",
    "axios": "^1.6.0",
    "bull": "^4.12.0",
    "ioredis": "^5.3.2",
    "winston": "^3.11.0",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.0",
    "cheerio": "^1.0.0-rc.12"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/bull": "^4.10.0",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.11.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.5.0",
    "jest": "^29.7.0"
  }
}
